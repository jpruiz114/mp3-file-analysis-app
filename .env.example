# Copy to .env and adjust as needed. All variables are optional — see src/config.ts
# for validation rules and src/server.ts for how they're consumed. Loaded via Node's
# built-in --env-file flag (see the dev/start scripts in package.json).

# Port the server listens on.
PORT=3000

# Maximum accepted upload size, in bytes.
MAX_UPLOAD_BYTES=209715200

# Per-upload processing time budget, in milliseconds. Uploads that take longer are
# aborted with 408 UPLOAD_TIMEOUT.
UPLOAD_TIME_BUDGET_MS=5000
